rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: qualquer usuário autenticado pode ler perfis e escrever no próprio.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /reading_progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /daily_missions/{missionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Tribos (Grupos): Usuários autenticados podem ler e ESCREVER (create/update).
    // Simplificado para debugar o erro de permissão.
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    // Ranking e Ligas (Read-only para usuários)
    match /leaderboards/{docId} {
      allow read: if request.auth != null;
    }

    // Bloquear tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
