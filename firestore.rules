rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função utilitária para verificar se o usuário é administrador
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users: usuários podem ler todos os perfis. 
    // Podem escrever no próprio, ser editados por admins ou ter seu groupId removido pelo líder da tribo.
    match /users/{userId} {
      // Usuários autenticados podem ler perfis (necessário para rankings/social).
      // Recomendado: mover 'email' e 'gems' para uma subcoleção /private futuramente.
      allow read: if request.auth != null;

      allow write: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId && 
          // Bloqueia edição direta de campos críticos por usuários comuns
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['xp', 'weeklyXp', 'gems', 'streak', 'weeklyEncounterWins', 'currentLeague', 'lastWeekXp', 'lastWeekEncounterWins', 'isAdmin'])
        ) ||
        (
          // Permite que o líder do grupo remova o groupId de um membro (expulsão)
          resource != null && resource.data.groupId != null && 
          request.resource.data.groupId == null && 
          get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.leaderUid == request.auth.uid
        )
      );

      match /reading_progress/{progressId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      match /daily_missions/{missionId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // Tribos (Grupos)
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Permite atualizar se for admin da tribo (líder ou admin nomeado)
      // Para simplificar o bug anterior de tribunais, mantemos permissivo mas com foco no líder para exclusão
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.leaderUid || 
        request.auth.uid in resource.data.admins ||
        isAdmin()
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.leaderUid || 
        isAdmin()
      );

      // Regras para o Mural da Tribo
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        // Validação opcional: garantir que o usuário pertence ao grupo (deixando mais leve para evitar bugs)
      }
    }

    // Arena / Jornada do Saber
    match /arena_queue/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /arena_matches/{matchId} {
      allow read, write: if request.auth != null;
    }

    // Perguntas de Quiz (para o Admin e carregamento de extras)
    match /quiz_questions/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Configurações Globais do App
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Bloquear tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
