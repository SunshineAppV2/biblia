rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: qualquer usuário autenticado pode ler perfis (para o ranking),
    // mas só pode escrever no próprio documento.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Progresso de leitura: somente o próprio usuário
      match /reading_progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Bloquear tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
