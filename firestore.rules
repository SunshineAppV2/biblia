rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: qualquer usuário autenticado pode ler perfis,
    // mas só pode escrever no próprio documento.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Progresso de leitura, favoritos e missões concluídas
      match /reading_progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /daily_missions/{missionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Tribos (Grupos): Usuários autenticados podem ver e criar.
    // Somente o líder pode atualizar configurações.
    match /groups/{groupId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.leaderUid == request.auth.uid || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberCount', 'totalXpWeek']))
      );
    }

    // Ranking e Ligas (Read-only para usuários)
    match /leaderboards/{docId} {
      allow read: if request.auth != null;
    }

    // Bloquear tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
